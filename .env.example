# Fireworks service account used by the scheduler to submit/poll/cancel jobs
# and to query live quota via GET /v1/accounts/{a}/quotas.
FIREWORKS_API_KEY=

# Prime Intellect API key for RFT (Hosted Training) jobs routed to primeintellect.
# Optional — when absent, the scheduler only uses Fireworks.
PRIME_API_KEY=

# Shared secret between pg_cron and the scheduler-tick Edge Function.
# Generate with: openssl rand -hex 32
SCHEDULER_SECRET=

# Supabase project configuration (operator / script use).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Client-side: set this to your issued sftq_* token when calling the scheduler API.
SFTQ_API_KEY=
